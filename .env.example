# ============================================================
# Diiff — Environment Variables Reference
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any file with real credentials.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- ElevenLabs (TTS narration — server-side only) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- OpenAI (text moderation — server-side only, replaces deprecated Perspective API) ---
OPENAI_API_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
EMAIL_FROM=Diiff <noreply@mail.diiff.app>
EMAIL_REPLY_TO=support@diiff.app

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Web Push (VAPID) ---
# Generate: node -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@diiff.app

# --- Error Tracking (Sentry) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- App Environment ---
APP_ENV=development

# --- World Labs (Phase 3) ---
NEXT_PUBLIC_WORLD_LABS_PROJECT_ID=
WORLD_LABS_API_KEY=

# --- Voice Rooms (Phase 2 — LiveKit) ---
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# --- Identity Verification (Phase 2 — Persona) ---
# PERSONA_API_KEY=
# PERSONA_ADULT_TEMPLATE_ID=
# PERSONA_MINOR_TEMPLATE_ID=
