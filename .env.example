# ============================================================
# Diiff — Environment Variables Reference
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any file with real credentials.
# ============================================================

# --- Supabase ---
# Your project URL from the Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# --- ElevenLabs (TTS narration) ---
# API key from elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Voice ID to use for scripted narration
ELEVENLABS_VOICE_ID=

# --- Google Perspective API (text moderation) ---
PERSPECTIVE_API_KEY=

# --- Auth ---
# Random secret for NextAuth session signing (min 32 chars)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- App Environment ---
# Values: development | staging | production
APP_ENV=development

# --- Error Tracking (Phase 1 — enable before production launch) ---
# NEXT_PUBLIC_SENTRY_DSN=

# --- Voice Rooms (Phase 2 — LiveKit integration) ---
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
